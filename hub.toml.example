# hub.toml — per-device context configuration
# Copy to hub.toml (gitignored) and edit for this machine.
#
# hub.toml is optional. When absent, hub runs with public integrations only.
# When present, it tells hub which integrations are relevant on this device.

[device]
# A label for this device — used in logs and diagnostics.
name = "work-laptop"   # or "home-laptop", "server", etc.

[integrations]
# List the integration slugs active on this device.
# Public integrations are always available; list them here if you want them enabled.
# Private integrations (from hub-private) require the symlinks to be in place first.
enabled = [
    "github-prs",
    # "loki-errors",    # example public integration
    # "my-private-one", # example private integration
]
