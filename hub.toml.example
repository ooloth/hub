# hub.toml — per-device project and workflow configuration
# Copy to hub.toml (gitignored) and edit for this machine.
# Or use hub-private/devices/<device>.toml (symlinked here by just setup-private).
#
# List only the projects and workflows relevant to this device.
# Work projects belong on the work laptop; personal projects on the personal laptop.

[[project]]
name = "hub"
repo = "ooloth/hub"
workflows = ["github-prs", "github-issues"]

# [[project]]
# name = "my-app"
# repo = "org/my-app"
# workflows = ["github-prs", "loki-errors"]

[monitor]
# Non-project workflows go here (home server health, calendar, etc.)
# workflows = ["home-server-health"]
