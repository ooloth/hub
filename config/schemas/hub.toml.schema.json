{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "hub.toml",
  "description": "Per-device project and workflow configuration for hub.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project": {
      "type": "array",
      "description": "Codebases to observe on this device.",
      "items": { "$ref": "#/definitions/project" }
    },
    "monitor": {
      "$ref": "#/definitions/monitor"
    }
  },
  "definitions": {
    "project": {
      "type": "object",
      "description": "A codebase and its associated workflows and environments.",
      "required": ["name", "repo"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable label for this project."
        },
        "repo": {
          "type": "string",
          "description": "GitHub repository in owner/name format.",
          "pattern": "^[^/]+/[^/]+$"
        },
        "workflow": {
          "type": "array",
          "description": "Codebase-level workflows (no deployment context).",
          "items": { "$ref": "#/definitions/workflow" }
        },
        "environment": {
          "type": "array",
          "description": "Deployment environments for this project.",
          "items": { "$ref": "#/definitions/environment" }
        }
      }
    },
    "environment": {
      "type": "object",
      "description": "A deployment environment. Carries platform context shared by all its workflows.",
      "required": ["env"],
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "string",
          "description": "Environment name — e.g. dev, uat, val, prod."
        },
        "gcp_project": {
          "type": "string",
          "description": "GCP project ID. Required by GCP-based workflows."
        },
        "gcp_region": {
          "type": "string",
          "description": "GCP region — e.g. us-central1."
        },
        "service": {
          "type": "string",
          "description": "Service or app name within the platform."
        },
        "cluster": {
          "type": "string",
          "description": "GKE cluster name."
        },
        "namespace": {
          "type": "string",
          "description": "Kubernetes namespace."
        },
        "workflow": {
          "type": "array",
          "description": "Workflows scoped to this environment.",
          "items": { "$ref": "#/definitions/workflow" }
        }
      }
    },
    "workflow": {
      "description": "A workflow instance. Add an entry here and a file in config/schemas/workflows/ when implementing a new workflow.",
      "oneOf": [
        { "$ref": "#/definitions/workflow_github_prs" },
        { "$ref": "#/definitions/workflow_github_issues" },
        { "$ref": "#/definitions/workflow_user_activity_gcp" }
      ]
    },
    "workflow_github_issues": {
      "type": "object",
      "description": "Surfaces open issues assigned to the authenticated user. Reads repo from parent project. Credentials via GITHUB_TOKEN.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "const": "github-issues" },
        "exclude_labels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Exclude issues carrying any of these labels — e.g. 'wontfix', 'duplicate'."
        }
      }
    },
    "workflow_github_prs": {
      "type": "object",
      "description": "Surfaces pull requests awaiting review. Reads repo from parent project. Credentials via GITHUB_TOKEN.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "const": "github-prs" },
        "exclude_authors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "GitHub usernames to exclude — e.g. 'dependabot'."
        }
      }
    },
    "workflow_user_activity_gcp": {
      "type": "object",
      "description": "Surfaces user activity from Google Cloud Logging. Reads gcp_project and service from parent environment. Credentials via GCP_TOKEN.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "const": "user-activity-gcp" },
        "include_users": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Only surface activity from these principals. When set, all others are ignored."
        },
        "exclude_users": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Exclude activity from these principals — e.g. bot service accounts."
        }
      }
    },
    "monitor": {
      "type": "object",
      "description": "Non-project observations not tied to any codebase.",
      "additionalProperties": false,
      "properties": {
        "workflow": {
          "type": "array",
          "description": "Device-level workflows.",
          "items": { "$ref": "#/definitions/workflow" }
        }
      }
    }
  }
}
